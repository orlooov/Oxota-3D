  m_Script: {fileID: 11500000, guid: f512d76c62d3a014db4bb8dbdbf1a633, type: 3}
  m_Name: Dialogue_Egor_Start
  m_EditorClassIdentifier: 
  lines:
  - speakerName: "\u0415\u0433\u043E\u0440"
    text: "\u042D\u0439, \u043F\u0430\u0440\u0435\u043D\u044C! \u0412\u0438\u0436\u0443,
      \u0441 \u0440\u0443\u0436\u044C\u0435\u043C. \u041D\u0435 \u043C\u0435\u0441\u0442\u043D\u044B\u0439,
      \u043F\u043E\u0434\u0438?"
  - speakerName: "\u0415\u0433\u043E\u0440"
    text: "\u0412\u043E\u043B\u043A\u0438 \u0441\u043E\u0432\u0441\u0435\u043C \u0440\u0430\u0441\u043F\u043E\u044F\u0441\u0430\u043B\u0438\u0441\u044C...
      \u0423\u043C\u0435\u043D\u044C\u0448\u0438 \u0438\u0445 \u043F\u043E\u0433\u043E\u043B\u043E\u0432\u044C\u0435,
      \u0445\u043E\u0442\u044F \u0431\u044B \u043E\u0434\u043D\u043E\u0433\u043E."
  - speakerName: "\u0415\u0433\u043E\u0440"
    text: "\u0414\u0435\u0440\u0436\u0438 \u0437\u0430\u0434\u0430\u043D\u0438\u0435.
      \u041B\u0435\u0441 - \u0442\u0430\u043C \u0438\u0445 \u0441\u0435\u0439\u0447\u0430\u0441
      \u043C\u043D\u043E\u0433\u043E."
  questToGive: {fileID: 11400000, guid: 4a12ae896086c7f4abbd76c0c0dcc80e, type: 2}
